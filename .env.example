# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ts_erp

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch 配置
ES_HOST=localhost
ES_PORT=9200
ES_USER=elastic
ES_PASSWORD=your_password

# JWT 配置
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Agent Service 配置
AGENT_SERVICE_URL=http://localhost:8001

# 日志配置
LOG_LEVEL=INFO
LOG_ES_INDEX=ts-erp-logs
